    "claim.signature_on_file": {
      "anchors": ["SIGNATURE ON FILE"]
    },
    "claim.date_signed": {
      "anchors": ["SIGNED", "DATE"],
      "date_formats": ["MM/DD/YYYY", "YYYY-MM-DD", "MMM DD, YYYY", "MMMM DD, YYYY"]
