    "patient.name": {
      "anchors": ["PATIENT'S NAME", "PATIENTS NAME"]
    },
    "insured.name": {
      "anchors": ["INSURED'S NAME", "INSUREDS NAME"]
    },

    "patient.date_of_birth": {
      "anchors": ["PATIENT'S BIRTH DATE", "PATIENTS BIRTH DATE"],
      "date_formats": ["MM DD YY", "MM/DD/YYYY", "YYYY-MM-DD", "MMM DD, YYYY", "MMMM DD, YYYY"]
    },
    "patient.sex": {
      "anchors": ["SEX", "PATIENT SEX"]
    },

    "patient.address": {
      "anchors": ["PATIENT'S ADDRESS", "PATIENTS ADDRESS"]
    },
    "insured.address": {
      "anchors": ["INSURED'S ADDRESS", "INSUREDS ADDRESS"]
    },
    "patient.phone": {
      "anchors": ["TELEPHONE", "PHONE"]
