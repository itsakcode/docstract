{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "Other/typed/v1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "document_id": { "type": "string" },
    "doc_type": { "const": "Other" },
    "schema_version": { "type": "string", "default": "v1" },

    "summary": { "type": ["string", "null"], "default": null },

    "notes": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },

    "key_values": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "key": { "type": "string" },
          "value": { "type": ["string", "null"], "default": null },

          "page": { "type": ["integer", "null"], "minimum": 1, "default": null },

          "evidence": {
            "type": ["string", "null"],
            "default": null,
            "description": "Short snippet or nearby text that supports this key/value"
          },

          "bbox": {
            "type": ["object", "null"],
            "default": null,
            "additionalProperties": false,
            "properties": {
              "left": { "type": "number", "minimum": 0, "maximum": 1 },
              "top": { "type": "number", "minimum": 0, "maximum": 1 },
              "width": { "type": "number", "minimum": 0, "maximum": 1 },
              "height": { "type": "number", "minimum": 0, "maximum": 1 }
            },
            "required": ["left", "top", "width", "height"]
          },

          "confidence": {
            "type": ["number", "null"],
            "minimum": 0,
            "maximum": 1,
            "default": null
          }
        },
        "required": ["key", "value", "page", "evidence", "bbox", "confidence"]
      }
    },

    "kv_map": {
      "type": "object",
      "default": {},
      "additionalProperties": { "type": ["string", "null"] },
      "description": "Convenience map of extracted key-values; keys should be short and human-readable"
    },

    "confidence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "overall": { "type": ["number", "null"], "minimum": 0, "maximum": 1, "default": null },
        "fields": {
          "type": "object",
          "default": {},
          "additionalProperties": { "type": ["number", "null"], "minimum": 0, "maximum": 1 }
        },
        "rationale": { "type": ["string", "null"], "default": null }
      },
      "required": ["overall", "fields", "rationale"]
    }
  },
  "required": ["document_id", "doc_type", "schema_version", "confidence"]
}
